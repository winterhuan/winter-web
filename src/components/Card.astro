---
// 列表卡片 —— 博客/工具/产品三类内容共用
// 标签可点击（用事件委托跳转，避免 a 嵌套 a）
import FormattedDate from './FormattedDate.astro';
import { readingTime } from '../lib/reading-time';
import { normalizeTags } from '../lib/content';

interface CardEntry {
  collection: 'blog' | 'tools' | 'products';
  slug: string;
  body?: string;
  data: {
    title: string;
    description?: string;
    date: Date;
    tags?: string[];
    url?: string;       // 外部试用链接（工具/产品）
    repo?: string;      // 源码仓库
    app?: boolean;      // 站内交互工具
    status?: string;    // 产品状态（如 beta/live）
  };
}

interface Props {
  entry: CardEntry;
}
const { entry } = Astro.props;
const { collection, slug, data, body } = entry;

// 标签归一化
const tags = normalizeTags(data.tags);
// 仅博客显示阅读时长（工具/产品无意义）
const minutes = collection === 'blog' && body ? readingTime(body) : 0;

// app 工具 → 跳交互页；有外部 url → 跳外链；否则跳详情页
const isExternal = Boolean(data.url);
const isApp = collection === 'tools' && data.app === true;
const href = isApp
  ? `/tools/${slug}/app`
  : isExternal
  ? data.url!
  : `/${collection === 'blog' ? 'blog' : collection}/${slug}`;
---
<article class="card">
  <a href={href} class="card-link" {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})} data-card-link>
    <div class="card-meta">
      <FormattedDate date={data.date} />
      {minutes > 0 && <span class="dot-sep">·</span>}
      {minutes > 0 && <span>{minutes} 分钟</span>}
      {data.status && <span class="status">{data.status}</span>}
    </div>
    <h3 class="card-title">{data.title}</h3>
    {data.description && <p class="card-desc">{data.description}</p>}
    {(tags.length > 0 || data.repo) && (
      <div class="card-foot">
        {tags.map((t) => (
          <span
            class="tag tag-clickable"
            data-href={`/${collection}/tags/${encodeURIComponent(t)}`}
            role="link"
            tabindex="0"
          >{t}</span>
        ))}
        {data.repo && <span class="repo muted">↗ 源码</span>}
      </div>
    )}
  </a>
</article>

<style>
  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    transition: border-color var(--transition), transform var(--transition);
  }
  .card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }
  .card-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    height: 100%;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
    color: var(--color-text-mute);
  }
  .status {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }
  .dot-sep { opacity: 0.5; }
  .card-title {
    font-size: var(--font-size-lg);
    line-height: 1.3;
  }
  .card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-soft);
    flex: 1;
  }
  .card-foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-top: auto;
  }
  .repo { font-size: var(--font-size-xs); }
  /* 可点击标签 */
  .tag-clickable {
    cursor: pointer;
  }
  .tag-clickable:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }
</style>

<script>
  // 事件委托：点击卡片内的标签 → 跳转到对应标签页
  // 用委托而非内联，避免每个标签绑一个监听器
  document.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('.tag-clickable') as HTMLElement | null;
    if (!target) return;
    const href = target.dataset.href;
    if (!href) return;
    e.preventDefault();   // 阻止冒泡到卡片链接
    e.stopPropagation();
    location.href = href;
  });
  // 键盘可访问：Enter / Space 触发
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const target = (e.target as HTMLElement).closest('.tag-clickable') as HTMLElement | null;
    if (!target) return;
    const href = target.dataset.href;
    if (!href) return;
    e.preventDefault();
    location.href = href;
  });
</script>
