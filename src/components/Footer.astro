---
// 页脚
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-inner">
    <p class="muted">© {year} {SITE_TITLE}. 用 <a href="https://astro.build" class="link-underline" target="_blank" rel="noopener">Astro</a> 构建.</p>
    {SOCIAL_LINKS.length > 0 && (
      <ul class="social">
        {SOCIAL_LINKS.map((link) => (
          <li>
            <a href={link.href} class="link-underline" target="_blank" rel="noopener">{link.label}</a>
          </li>
        ))}
      </ul>
    )}
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-24);
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-8);
    font-size: var(--font-size-sm);
  }
  .footer-inner p { color: var(--color-text-mute); }
  .social {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .social a {
    color: var(--color-text-mute);
    font-size: var(--font-size-sm);
  }
  .social a:hover { color: var(--color-text); }
  @media (max-width: 600px) {
    .footer-inner { flex-direction: column; align-items: flex-start; gap: var(--space-3); }
  }
</style>
