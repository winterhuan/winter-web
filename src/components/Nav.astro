---
// 顶部导航
import { NAV_LINKS, SITE_TITLE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="site-header">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label={SITE_TITLE}>
      <Logo size={22} />
      <span class="brand-text">{SITE_TITLE}</span>
    </a>

    <nav aria-label="主导航">
      <ul class="nav-list">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', 'link-underline', { active: isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: var(--font-size-base);
  }
  .brand :global(.taiji-logo) {
    transition: transform 400ms ease;
  }
  .brand:hover :global(.taiji-logo) {
    transform: rotate(180deg); /* hover 时太极转半圈 */
  }
  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-mute);
    transition: color var(--transition);
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--color-text);
  }
  .nav-link.active {
    background-size: 100% 1px; /* 保持下划线常显 */
  }
  @media (max-width: 600px) {
    .brand-text { display: none; }
    .nav-list { gap: var(--space-4); }
  }
</style>
