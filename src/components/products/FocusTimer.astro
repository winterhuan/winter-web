---
// Focus 专注计时器 —— 番茄工作法
---
<div class="focus-tool">
  <!-- 圆形进度环 + 倒计时 -->
  <div class="focus-ring-wrap">
    <svg class="focus-ring" viewBox="0 0 200 200" data-ring>
      <circle class="ring-bg" cx="100" cy="100" r="90" />
      <circle class="ring-fill" cx="100" cy="100" r="90" data-ring-fill />
    </svg>
    <div class="focus-ring-inner">
      <div class="phase-label" data-phase-label>准备开始</div>
      <div class="time" data-time>25:00</div>
    </div>
  </div>

  <!-- 控制按钮 -->
  <div class="focus-controls">
    <button class="btn primary" data-action="start">▶ 开始</button>
    <button class="btn" data-action="pause" hidden>⏸ 暂停</button>
    <button class="btn ghost" data-action="skip">⏭ 跳过</button>
    <button class="btn ghost" data-action="reset">↺ 重置</button>
  </div>

  <!-- 任务清单 -->
  <div class="focus-section">
    <form class="task-form" data-task-form>
      <input class="task-input" data-task-input placeholder="当前要专注的任务…" />
      <button class="btn" type="submit">添加</button>
    </form>
    <ul class="task-list" data-task-list></ul>
  </div>

  <!-- 环境音（内嵌小栏） -->
  <div class="focus-audio">
    <label class="ambient-toggle">
      <span class="ambient-icon">🔇</span>
      <select data-ambient>
        <option value="none">关闭</option>
        <option value="white">白噪音</option>
        <option value="rain">雨声</option>
      </select>
    </label>
  </div>

  <!-- 统计 -->
  <div class="focus-section focus-stats">
    <div class="stats-summary">
      <div class="stat">
        <span class="stat-icon">🍅</span>
        <span class="stat-num" data-stat-today>0</span>
        <span class="stat-label">今日</span>
      </div>
      <div class="stat stat-divider"></div>
      <div class="stat">
        <span class="stat-num" data-stat-week>0</span>
        <span class="stat-label">本周</span>
      </div>
      <div class="stat stat-divider"></div>
      <div class="stat">
        <span class="stat-num" data-stat-total>0h</span>
        <span class="stat-label">累计</span>
      </div>
    </div>
    <div class="stats-chart-wrap">
      <div class="chart-heading">最近 7 天</div>
      <div class="stats-chart" data-stats-chart></div>
    </div>
  </div>
</div>

<style>
  .focus-tool {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-6) 0 var(--space-12);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ─── 圆形进度环 ─────────────────────────────────────────── */
  .focus-ring-wrap {
    position: relative;
    width: 200px;
    height: 200px;
    margin: var(--space-4) auto;
  }
  .focus-ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .ring-bg {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 8;
  }
  .ring-fill {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 565.486; /* 2 * π * 90 ≈ 565.486 */
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.3s linear, stroke 0.5s;
  }
  .focus-ring-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
  }
  .phase-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-mute);
    transition: color 0.5s;
  }
  .time {
    font-family: var(--font-mono);
    font-size: 3.25rem;
    font-weight: 700;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    transition: color 0.5s;
  }

  /* 阶段色彩：idle=默认, focus=暖橙, break=青绿 */
  .focus-tool[data-phase="focus"] .ring-fill { stroke: #f59e0b; }
  .focus-tool[data-phase="focus"] .phase-label { color: #f59e0b; }
  .focus-tool[data-phase="focus"] .time { color: #f59e0b; }
  .focus-tool[data-phase="short-break"] .ring-fill,
  .focus-tool[data-phase="long-break"] .ring-fill { stroke: #14b8a6; }
  .focus-tool[data-phase="short-break"] .phase-label,
  .focus-tool[data-phase="long-break"] .phase-label { color: #14b8a6; }
  .focus-tool[data-phase="short-break"] .time,
  .focus-tool[data-phase="long-break"] .time { color: #14b8a6; }

  /* ─── 控制按钮 ───────────────────────────────────────────── */
  .focus-controls {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn {
    padding: var(--space-2) var(--space-5);
    font-size: var(--font-size-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-text);
    cursor: pointer;
    transition: all var(--transition);
    font-family: var(--font-mono);
  }
  .btn:hover {
    border-color: var(--color-border-strong);
    background: var(--color-bg);
  }
  .btn.primary {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: var(--color-accent);
    padding-inline: var(--space-8);
    font-weight: 600;
  }
  .btn.primary:hover {
    opacity: 0.88;
    background: var(--color-accent);
  }
  .btn.ghost {
    border-color: transparent;
    background: transparent;
    opacity: 0.55;
  }
  .btn.ghost:hover { opacity: 0.85; border-color: var(--color-border); }
  .btn[hidden] { display: none; }

  /* ─── 公用区块卡片 ───────────────────────────────────────── */
  .focus-section {
    width: 100%;
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }

  /* ─── 任务清单 ───────────────────────────────────────────── */
  .task-form {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
    align-items: stretch;
  }
  .task-input {
    flex: 1;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
    outline: none;
    transition: border-color var(--transition);
  }
  .task-input:focus { border-color: var(--color-accent); }
  .task-form .btn {
    font-size: var(--font-size-sm);
    font-family: var(--font-mono);
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg);
    border-color: var(--color-border);
    color: var(--color-text);
  }
  .task-form .btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-bg);
  }

  /* 任务列表 */
  .task-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .task-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--color-border);
    transition: background 0.15s, border-color 0.15s;
    font-size: var(--font-size-sm);
    cursor: default;
  }
  .task-item:last-child { border-bottom: none; }
  .task-item:hover { background: var(--color-surface); }

  /* 焦点任务高亮 */
  .task-item.is-focused {
    background: linear-gradient(90deg, rgba(245,158,11,0.12) 0%, rgba(245,158,11,0.02) 100%);
    border-left: 3px solid #f59e0b;
    padding-left: 13px; /* 补偿左边框宽度 */
  }

  /* 已完成任务 */
  .task-item.is-done { opacity: 0.45; }
  .task-item.is-done .task-title { text-decoration: line-through; }

  /* 拖拽手柄 */
  .drag-handle {
    cursor: grab;
    color: var(--color-text-mute);
    font-size: 14px;
    user-select: none;
    flex-shrink: 0;
    line-height: 1;
    opacity: 0.4;
    transition: opacity 0.15s;
  }
  .task-item:hover .drag-handle { opacity: 0.7; }
  .task-item.drag-over { border-top: 2px solid var(--color-accent); }
  .task-item.dragging { opacity: 0.5; }

  /* 圆形 checkbox */
  .task-checkbox {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid var(--color-border-strong);
    background: transparent;
    flex-shrink: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: border-color 0.2s, background 0.2s;
  }
  .task-checkbox:hover { border-color: var(--color-accent); }
  .task-item.is-focused .task-checkbox { border-color: #f59e0b; }
  .task-item.is-done .task-checkbox {
    background: #4ade80;
    border-color: #4ade80;
  }
  .task-item.is-done .task-checkbox::after {
    content: '✓';
    color: #1a1a2e;
    font-size: 10px;
    font-weight: 700;
  }

  /* 聚焦 checkbox 脉冲动点 */
  .task-item.is-focused .task-checkbox::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f59e0b;
    animation: checkbox-pulse 1.5s infinite;
  }
  @keyframes checkbox-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .task-title {
    flex: 1;
    line-height: 1.6;
  }
  .task-pomos {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-mute);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .task-delete {
    background: none;
    border: none;
    color: var(--color-text-mute);
    cursor: pointer;
    font-size: var(--font-size-sm);
    padding: 2px 4px;
    border-radius: var(--radius);
    opacity: 0;
    transition: opacity 0.15s, color 0.15s;
    line-height: 1;
  }
  .task-item:hover .task-delete { opacity: 0.6; }
  .task-delete:hover { opacity: 1 !important; color: #f87171; }

  /* 空状态 */
  .task-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 28px 20px;
    text-align: center;
    color: var(--color-text-mute);
    gap: 6px;
  }
  .task-empty-icon { font-size: 28px; line-height: 1; opacity: 0.5; }
  .task-empty-text { font-size: var(--font-size-sm); }

  /* ─── 环境音（内嵌小栏）──────────────────────────────────── */
  .focus-audio { margin-top: calc(-1 * var(--space-3)); }
  .ambient-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-mute);
  }
  .ambient-icon { font-size: var(--font-size-base); }
  .ambient-toggle select {
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: transparent;
    color: var(--color-text-mute);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    cursor: pointer;
  }
  .ambient-toggle select:focus { outline: none; border-color: var(--color-border-strong); }

  /* ─── 统计 ───────────────────────────────────────────────── */
  .focus-stats { text-align: center; }
  .stats-summary {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-2) 0 var(--space-4);
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    min-width: 60px;
  }
  .stat-icon { font-size: var(--font-size-lg); line-height: 1; }
  .stat-num {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.1;
  }
  .stat-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-mute);
    font-family: var(--font-mono);
  }
  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--color-border);
    min-width: 0;
  }
  .stats-chart-wrap {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }
  .chart-heading {
    font-size: var(--font-size-xs);
    color: var(--color-text-mute);
    font-family: var(--font-mono);
    margin-bottom: var(--space-3);
  }
  .stats-chart {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    height: 72px;
  }
  .chart-bar {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }
  .chart-bar-fill {
    width: 100%;
    max-width: 36px;
    border-radius: 4px 4px 0 0;
    min-height: 2px;
    transition: height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    background: linear-gradient(to top, var(--color-accent), color-mix(in srgb, var(--color-accent) 60%, transparent));
  }
  .chart-bar-fill.active {
    background: linear-gradient(to top, var(--color-accent), color-mix(in srgb, var(--color-accent) 40%, transparent));
    opacity: 1;
  }
  .chart-bar-label {
    font-size: 0.6rem;
    color: var(--color-text-mute);
    font-family: var(--font-mono);
    line-height: 1;
  }

  @media (max-width: 500px) {
    .focus-ring-wrap { width: 160px; height: 160px; }
    .ring-bg, .ring-fill { stroke-width: 6; }
    .ring-fill { stroke-dasharray: 502.654; } /* 2*π*80 */
    .time { font-size: 2.5rem; }
  }
</style>

<script>
  import {
    DEFAULT_SETTINGS, defaultTimerState, phaseDurationMs, nextPhase,
    type TimerState, type Settings, type Phase,
  } from '../../lib/timer-engine';
  import { AudioKit } from '../../lib/audio';

  const PHASE_LABELS: Record<Phase, string> = {
    'idle': '准备开始', 'focus': '专注中',
    'short-break': '短休息', 'long-break': '长休息',
  };

  const RING_CIRCUMFERENCE = 565.486; // 2*π*90

  const SETTINGS_KEY = 'focus-settings';
  const STATE_KEY = 'focus-timer';
  const STATS_KEY = 'focus-stats';
  const TASKS_KEY = 'focus-tasks';

  function loadSettings(): Settings {
    try { const r = localStorage.getItem(SETTINGS_KEY); if (r) return { ...DEFAULT_SETTINGS, ...JSON.parse(r) }; } catch (e) {}
    return { ...DEFAULT_SETTINGS };
  }
  function loadState(): TimerState {
    try { const r = localStorage.getItem(STATE_KEY); if (r) return { ...defaultTimerState(), ...JSON.parse(r) }; } catch (e) {}
    return defaultTimerState();
  }
  function saveState(s: TimerState) { try { localStorage.setItem(STATE_KEY, JSON.stringify(s)); } catch (e) {} }

  const toolEl = document.querySelector('.focus-tool') as HTMLElement;
  const timeEl = document.querySelector('[data-time]') as HTMLElement;
  const phaseLabelEl = document.querySelector('[data-phase-label]') as HTMLElement;
  const ringFillEl = document.querySelector('[data-ring-fill]') as SVGCircleElement;
  const startBtn = document.querySelector('[data-action="start"]') as HTMLButtonElement;
  const pauseBtn = document.querySelector('[data-action="pause"]') as HTMLButtonElement;
  const skipBtn = document.querySelector('[data-action="skip"]') as HTMLButtonElement;
  const resetBtn = document.querySelector('[data-action="reset"]') as HTMLButtonElement;

  const settings = loadSettings();
  let state = loadState();
  let rafId: number | null = null;
  const audio = new AudioKit();

  function formatMs(ms: number): string {
    const s = Math.max(0, Math.ceil(ms / 1000));
    return `${String(Math.floor(s / 60)).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`;
  }
  function remainingMs(): number {
    if (state.endTime != null) return Math.max(0, state.endTime - Date.now());
    if (state.pausedRemaining != null) return state.pausedRemaining;
    if (state.phase === 'idle') return phaseDurationMs('focus', settings);
    return 0;
  }
  function progressFraction(): number {
    if (state.phase === 'idle') return 1;
    const total = phaseDurationMs(state.phase, settings);
    if (total === 0) return 1;
    return remainingMs() / total;
  }

  function render() {
    const rem = remainingMs();
    const frac = progressFraction();
    timeEl.textContent = formatMs(rem);
    phaseLabelEl.textContent = PHASE_LABELS[state.phase];
    if (ringFillEl) ringFillEl.style.strokeDashoffset = String(RING_CIRCUMFERENCE * (1 - frac));
    if (toolEl) toolEl.dataset.phase = state.phase;
    const running = state.endTime != null;
    startBtn.hidden = running;
    pauseBtn.hidden = !running;
    document.title = `${formatMs(rem)} · ${PHASE_LABELS[state.phase]}`;
  }

  function start() {
    audio.ensureContext();
    if (state.phase === 'idle') state.phase = 'focus';
    state.endTime = Date.now() + remainingMs();
    state.pausedRemaining = null;
    saveState(state);
    render();
    loop();
  }
  function pause() {
    if (state.endTime == null) return;
    state.pausedRemaining = state.endTime - Date.now();
    state.endTime = null;
    saveState(state);
    render();
    stopLoop();
  }

  function completePhase() {
    stopLoop();
    const wasFocus = state.phase === 'focus';
    if (wasFocus) {
      state.completedFocus += 1;
      recordFocusComplete();
      recordFocusForTask();
    }
    const { phase } = nextPhase(state.phase, wasFocus ? state.completedFocus - 1 : state.completedFocus, settings);
    state.phase = phase;
    state.endTime = Date.now() + phaseDurationMs(phase, settings);
    state.pausedRemaining = null;
    saveState(state);
    if (settings.soundOn) audio.playChime();
    render();
    if (state.phase !== 'idle') loop();
  }
  function skip() { if (state.phase !== 'idle') completePhase(); }
  function reset() {
    stopLoop();
    state = defaultTimerState();
    saveState(state);
    render();
  }

  function loop() {
    stopLoop();
    const tick = () => {
      if (state.endTime != null && Date.now() >= state.endTime) { completePhase(); return; }
      render();
      rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);
  }
  function stopLoop() { if (rafId != null) { cancelAnimationFrame(rafId); rafId = null; } }

  document.addEventListener('visibilitychange', () => {
    if (!document.hidden && state.endTime != null) {
      if (Date.now() >= state.endTime) completePhase(); else render();
    }
  });

  // ─── 统计 ─────────────────────────────────────────────────
  interface DayStat { pomodoros: number; focusMs: number; }
  type Stats = Record<string, DayStat>;
  function loadStats(): Stats { try { const r = localStorage.getItem(STATS_KEY); if (r) return JSON.parse(r); } catch (e) {} return {}; }
  function saveStats(s: Stats) { try { localStorage.setItem(STATS_KEY, JSON.stringify(s)); } catch (e) {} }
  function todayKey(): string { const d = new Date(); return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }

  function recordFocusComplete() {
    const stats = loadStats();
    const key = todayKey();
    const day = stats[key] || { pomodoros: 0, focusMs: 0 };
    day.pomodoros += 1; day.focusMs += settings.focusMin * 60_000;
    stats[key] = day; saveStats(stats);
    renderStats();
  }

  function renderStats() {
    const stats = loadStats();
    const today = stats[todayKey()]?.pomodoros || 0;
    const days: { key: string; label: string; pomodoros: number }[] = [];
    let weekTotal = 0, grandTotalMs = 0;
    const now = new Date();
    for (let i = 6; i >= 0; i--) {
      const d = new Date(now); d.setDate(now.getDate() - i);
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
      const p = stats[key]?.pomodoros || 0;
      const idx = days.length;
      const label = String(d.getDate());
      days.push({ key, label, pomodoros: p });
      weekTotal += p;
    }
    Object.values(stats).forEach(d => { grandTotalMs += d.focusMs; });
    const setNum = (sel: string, val: string) => { const el = document.querySelector(sel); if (el) el.textContent = val; };
    setNum('[data-stat-today]', String(today));
    setNum('[data-stat-week]', String(weekTotal));
    setNum('[data-stat-total]', `${(grandTotalMs / 3600000).toFixed(1)}h`);
    const chartEl = document.querySelector('[data-stats-chart]');
    if (chartEl) {
      const max = Math.max(1, ...days.map(d => d.pomodoros));
      chartEl.innerHTML = days.map((d, i) => {
        const h = Math.round(d.pomodoros / max * 58);
        const active = i === days.length - 1 ? ' active' : '';
        return `<div class="chart-bar"><div class="chart-bar-fill${active}" style="height:${h}px"></div><div class="chart-bar-label">${d.label}</div></div>`;
      }).join('');
    }
  }
  renderStats();

  // ─── 任务清单 ─────────────────────────────────────────────
  interface Task { id: string; title: string; pomodoros: number; done: boolean; createdAt: number; }
  function loadTasks(): Task[] { try { const r = localStorage.getItem(TASKS_KEY); if (r) return JSON.parse(r); } catch (e) {} return []; }
  function saveTasks(tasks: Task[]) { try { localStorage.setItem(TASKS_KEY, JSON.stringify(tasks)); } catch (e) {} }
  const taskListEl = document.querySelector('[data-task-list]') as HTMLElement;
  const taskForm = document.querySelector('[data-task-form]') as HTMLFormElement;
  const taskInput = document.querySelector('[data-task-input]') as HTMLInputElement;
  function esc(s: string) { return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!)); }

  function renderTasks() {
    if (!taskListEl) return;
    const tasks = loadTasks();
    if (tasks.length === 0) {
      taskListEl.innerHTML = `<div class="task-empty">
        <span class="task-empty-icon">📝</span>
        <span class="task-empty-text">还没有任务</span>
        <span class="task-empty-text">添加一个开始专注吧 🎯</span>
      </div>`;
      return;
    }
    taskListEl.innerHTML = tasks.map(t => `
      <li class="task-item${t.id === state.currentTaskId ? ' is-focused' : ''}${t.done ? ' is-done' : ''}" data-task-id="${t.id}" draggable="true">
        <span class="drag-handle" aria-hidden="true">⋮⋮</span>
        <button class="task-checkbox" data-task-toggle="${t.id}" aria-label="${t.done ? '取消完成' : '完成任务'}"></button>
        <span class="task-title">${esc(t.title)}</span>
        <span class="task-pomos">${t.pomodoros > 0 ? '🍅 ' + t.pomodoros : ''}</span>
        <button class="task-delete" data-task-delete="${t.id}" aria-label="删除任务">✕</button>
      </li>`).join('');
  }

  taskForm.addEventListener('submit', e => {
    e.preventDefault();
    const title = taskInput.value.trim();
    if (!title) return;
    const tasks = loadTasks();
    tasks.push({ id: crypto.randomUUID(), title, pomodoros: 0, done: false, createdAt: Date.now() });
    saveTasks(tasks); taskInput.value = ''; renderTasks();
  });

  taskListEl.addEventListener('click', e => {
    const t = e.target as HTMLElement;
    const item = t.closest('[data-task-id]') as HTMLElement | null;
    if (!item) return;
    const id = item.dataset.taskId!;
    const tasks = loadTasks();

    // 删除按钮
    if (t.closest('[data-task-delete]')) {
      const f = tasks.filter(x => x.id !== id);
      saveTasks(f);
      if (state.currentTaskId === id) { state.currentTaskId = null; saveState(state); }
      renderTasks(); return;
    }

    // 切换完成状态
    if (t.closest('[data-task-toggle]')) {
      const m = tasks.find(x => x.id === id);
      if (m) { m.done = !m.done; saveTasks(tasks); }
      renderTasks(); return;
    }

    // 点击任务主体 → 设为当前聚焦任务
    state.currentTaskId = state.currentTaskId === id ? null : id;
    saveState(state); renderTasks();
  });

  // ─── 拖拽排序 ─────────────────────────────────────────────
  let dragSrcEl: HTMLElement | null = null;

  function taskSyncOrder() {
    const items = taskListEl.querySelectorAll('[data-task-id]');
    const newOrder: string[] = [];
    items.forEach(el => newOrder.push((el as HTMLElement).dataset.taskId!));
    const tasks = loadTasks();
    const reordered = newOrder.map(id => tasks.find(t => t.id === id)!).filter(Boolean);
    saveTasks(reordered);
  }

  taskListEl.addEventListener('dragstart', (e) => {
    const el = (e.target as HTMLElement).closest('[data-task-id]') as HTMLElement;
    if (!el) { e.preventDefault(); return; }
    dragSrcEl = el;
    e.dataTransfer!.effectAllowed = 'move';
    el.classList.add('dragging');
  });

  taskListEl.addEventListener('dragend', () => {
    if (dragSrcEl) {
      dragSrcEl.classList.remove('dragging');
      taskSyncOrder();
      renderTasks();
    }
    dragSrcEl = null;
    taskListEl.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
  });

  taskListEl.addEventListener('dragover', (e) => {
    e.preventDefault();
    e.dataTransfer!.dropEffect = 'move';
  });

  taskListEl.addEventListener('dragenter', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('[data-task-id]') as HTMLElement;
    if (!target || target === dragSrcEl) return;
    taskListEl.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    target.classList.add('drag-over');
  });

  taskListEl.addEventListener('dragleave', (e) => {
    const target = (e.target as HTMLElement).closest('[data-task-id]') as HTMLElement;
    if (target) target.classList.remove('drag-over');
  });

  taskListEl.addEventListener('drop', (e) => {
    e.preventDefault();
    taskListEl.querySelectorAll('.drag-over').forEach(el => el.classList.remove('drag-over'));
    const target = (e.target as HTMLElement).closest('[data-task-id]') as HTMLElement;
    if (!target || !dragSrcEl || target === dragSrcEl) return;
    taskListEl.insertBefore(dragSrcEl, target);
    taskSyncOrder();
  });

  function recordFocusForTask() {
    if (!state.currentTaskId) return;
    const tasks = loadTasks();
    const m = tasks.find(x => x.id === state.currentTaskId);
    if (m) { m.pomodoros += 1; saveTasks(tasks); renderTasks(); }
  }
  renderTasks();

  // ─── 环境音 ───────────────────────────────────────────────
  const ambientSelect = document.querySelector('[data-ambient]') as HTMLSelectElement;
  if (ambientSelect) {
    ambientSelect.value = settings.ambient;
    ambientSelect.addEventListener('change', () => {
      audio.ensureContext();
      const mode = ambientSelect.value as 'none' | 'white' | 'rain';
      settings.ambient = mode;
      try { localStorage.setItem(SETTINGS_KEY, JSON.stringify(settings)); } catch (e) {}
      audio.setAmbient(mode);
    });
  }

  // ─── 绑定 ─────────────────────────────────────────────────
  startBtn.addEventListener('click', start);
  pauseBtn.addEventListener('click', pause);
  skipBtn.addEventListener('click', skip);
  resetBtn.addEventListener('click', reset);
  render();
</script>
